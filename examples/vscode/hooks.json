{
  "version": 1,
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "examples/vscode/hook-wrapper.sh",
        "windows": "examples\\vscode\\hook-wrapper.ps1",
        "env": {
          "LILITH_ZERO_EVENT": "PreToolUse"
        },
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "examples/vscode/hook-wrapper.sh",
        "windows": "examples\\vscode\\hook-wrapper.ps1",
        "env": {
          "LILITH_ZERO_EVENT": "PostToolUse"
        },
        "timeout": 10
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "examples/vscode/hook-wrapper.sh",
        "windows": "examples\\vscode\\hook-wrapper.ps1",
        "env": {
          "LILITH_ZERO_EVENT": "SessionStart"
        },
        "timeout": 5
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "examples/vscode/hook-wrapper.sh",
        "windows": "examples\\vscode\\hook-wrapper.ps1",
        "env": {
          "LILITH_ZERO_EVENT": "SessionEnd"
        },
        "timeout": 5
      }
    ]
  }
}
